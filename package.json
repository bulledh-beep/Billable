{
  "name": "billable",
  "version": "1.0.3",
  "description": "Professional freelance time tracking and invoice generation",
  "author": "Billable App",
  "license": "MIT",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder --mac --config",
    "build:dir": "vite build && electron-builder --mac dir --config",
    "build:vite": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "electron-store": "^8.2.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.billable.app",
    "productName": "Billable",
    "mac": {
      "target": [
        {
          "target": "dmg"
        },
        {
          "target": "dir"
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.productivity",
      "identity": null
    },
    "dmg": {
      "title": "Billable"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "resources/trayIconTemplate.png",
        "to": "trayIconTemplate.png"
      },
      {
        "from": "resources/trayIconTemplate@2x.png",
        "to": "trayIconTemplate@2x.png"
      },
      {
        "from": "resources/trayIconActiveTemplate.png",
        "to": "trayIconActiveTemplate.png"
      },
      {
        "from": "resources/trayIconActiveTemplate@2x.png",
        "to": "trayIconActiveTemplate@2x.png"
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}
